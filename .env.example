# Public site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Auth.js
AUTH_SECRET=                              # openssl rand -base64 32
AUTH_TRUST_HOST=true
ADMIN_EMAIL=lollo.barbagelata@gmail.com
ADMIN_IP_ALLOWLIST=                       # optional CSV of CIDRs, e.g. "203.0.113.0/24,198.51.100.42/32"

# Database (Neon Postgres)
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=revoring-media
R2_PUBLIC_HOST=                            # e.g. pub-xxx.r2.dev or cdn.revoring.com
REVORING_R2_PUBLIC_HOST=                   # mirror for next.config.ts image domain

# SMTP (client's company mailbox — provided in a later phase)
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Revoring <noreply@revoring.com>"

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Analytics (optional — only loaded after consent)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Observability
SENTRY_DSN=
