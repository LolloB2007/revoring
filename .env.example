# Public site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Auth.js — AUTH_SECRET required. Generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_TRUST_HOST=true
ADMIN_EMAIL=lollo.barbagelata@gmail.com
ADMIN_IP_ALLOWLIST=

# JSON file store
#   Tables are written to ./data/<table>.json. No database to provision.
#   Sign in as admin: email = ADMIN_EMAIL, password = "admin" (hardcoded in lib/auth.ts).

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Cloudflare R2 (S3-compatible, for product/blog image uploads)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=revoring-media
R2_PUBLIC_HOST=
REVORING_R2_PUBLIC_HOST=

# SMTP — client's company mailbox. Leave blank in dev; emails get logged.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Revoring <noreply@revoring.com>"

# Upstash Redis (rate limiting) — leave blank in dev to disable rate-limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Analytics (loaded only after cookie consent)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Observability
SENTRY_DSN=
